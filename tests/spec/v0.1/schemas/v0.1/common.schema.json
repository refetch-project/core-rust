{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://refetch.dev/schemas/v0.1/common.schema.json",
  "$defs": {
    "specVersion": {
      "const": "v0.1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9:-]*$"
    },
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/token"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "sourceSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "evidenceRefs"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^source\\.[a-z][A-Za-z0-9_.-]*$"
        },
        "value": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "analysisSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "evidenceRefs"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^analysis\\.[a-z][A-Za-z0-9_.-]*$"
        },
        "value": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "clusterAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "id",
        "evidenceRefs"
      ],
      "properties": {
        "namespace": {
          "$ref": "#/$defs/token"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  }
}